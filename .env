# --- APP DATABASE (Il tuo DB principale) ---
APP_DB_USER=app_user
APP_DB_PASSWORD=app_password_super_sicura
APP_DB_NAME=app_database

# --- SUPERSET INTERNAL DATABASE ---
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=superset_password
SUPERSET_DB_NAME=superset

# --- SUPERSET CONFIGURATION ---
# Genera una chiave segreta complessa (es. con `openssl rand -base64 42`)
SUPERSET_SECRET_KEY=UnaChiaveSegretaMoltoLungaEComplessa123!
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin